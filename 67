    <script>
        // ==============================================================
        // 1. DOM Interactions (Tabs, Reveal, Scroll Navbar)
        // ==============================================================
        
        // Navbar Scrolled State
        const nav = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) nav.classList.add('scrolled');
            else nav.classList.remove('scrolled');
        });

        // Tabs Logic
        const tabBtns = document.querySelectorAll('.tab-btn');
        const tabContents = document.querySelectorAll('.tab-content');
        
        tabBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                tabBtns.forEach(b => b.classList.remove('active'));
                tabContents.forEach(c => c.classList.remove('active'));
                
                btn.classList.add('active');
                document.getElementById(btn.dataset.target).classList.add('active');
            });
        });

        // Scroll Reveal Observer
        const revealElements = document.querySelectorAll('.reveal');
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        
        revealElements.forEach(el => revealObserver.observe(el));


        // ==============================================================
        // 2. THREE.JS 3D Environment
        // ==============================================================
        
        // Safety check for reduced motion
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        
        if (!prefersReducedMotion && typeof THREE !== 'undefined') {
            const canvas = document.getElementById('webgl-canvas');
            const scene = new THREE.Scene();
            
            // Camera Setup
            const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.z = 20;

            // Renderer Setup
            const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

            // ------------- A. Background Particles -------------
            const particlesGeometry = new THREE.BufferGeometry();
            const particlesCount = window.innerWidth < 768 ? 400 : 1000;
            const posArray = new Float32Array(particlesCount * 3);
            
            for(let i = 0; i < particlesCount * 3; i++) {
                // Spread widely in background
                posArray[i] = (Math.random() - 0.5) * 60;
            }
            particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const particlesMaterial = new THREE.PointsMaterial({
                size: 0.05,
                color: 0x00eaff,
                transparent: true,
                opacity: 0.3,
                blending: THREE.AdditiveBlending
            });
            const particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
            scene.add(particlesMesh);

            // ------------- B. Hero Neural Network -------------
            const heroGroup = new THREE.Group();
            
            // Icosahedron logic creates a nice "connected nodes" look
            const networkGeo = new THREE.IcosahedronGeometry(3.5, 1);
            
            // Nodes (Points)
            const nodeMat = new THREE.PointsMaterial({ color: 0xffffff, size: 0.15 });
            const nodes = new THREE.Points(networkGeo, nodeMat);
            
            // Connections (Wireframe)
            const edgeMat = new THREE.LineBasicMaterial({ color: 0x00eaff, transparent: true, opacity: 0.25 });
            const edges = new THREE.LineSegments(new THREE.WireframeGeometry(networkGeo), edgeMat);
            
            heroGroup.add(nodes);
            heroGroup.add(edges);
            scene.add(heroGroup);

            // ------------- C. Course Crystals -------------
            // Vi mapper disse til specifikke DOM elementer for perfekt responsivitet
            const crystalData = [
                { id: 'D', color: 0x10b981 }, // Grøn
                { id: 'C', color: 0x3b82f6 }, // Blå
                { id: 'B', color: 0x8b5cf6 }, // Lilla
                { id: 'A', color: 0xfbbf24 }  // Guld
            ];
            
            const crystals = [];
            const crystalTargets = []; // DOM placeholders

            // Belysning for materialerne
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
            scene.add(ambientLight);
            const dirLight = new THREE.DirectionalLight(0xffffff, 1);
            dirLight.position.set(5, 5, 5);
            scene.add(dirLight);

            // Henter placeholders fra DOM
            document.querySelectorAll('.course-card').forEach((card) => {
                const level = card.getAttribute('data-level');
                const conf = crystalData.find(c => c.id === level);
                const placeholder = card.querySelector('.crystal-placeholder');
                
                if (conf && placeholder) {
                    // Geometri: Octahedron ser ud som krystaller
                    const geo = new THREE.OctahedronGeometry(1.2, 0);
                    const mat = new THREE.MeshStandardMaterial({ 
                        color: 0x111111,
                        emissive: conf.color,
                        emissiveIntensity: 0.4,
                        roughness: 0.1,
                        metalness: 0.8,
                        wireframe: true
                    });
                    const mesh = new THREE.Mesh(geo, mat);
                    
                    // Gem baseline scale til hover effekter
                    mesh.userData = { 
                        baseScale: 1,
                        targetScale: 1,
                        domElement: placeholder 
                    };
                    
                    scene.add(mesh);
                    crystals.push(mesh);

                    // Mouse interactions for the CSS card triggering the 3D mesh
                    card.addEventListener('mouseenter', () => mesh.userData.targetScale = 1.3);
                    card.addEventListener('mouseleave', () => mesh.userData.targetScale = 1);
                }
            });


            // ------------- Interactive State -------------
            let mouseX = 0;
            let mouseY = 0;
            let targetX = 0;
            let targetY = 0;
            const windowHalfX = window.innerWidth / 2;
            const windowHalfY = window.innerHeight / 2;

            document.addEventListener('mousemove', (event) => {
                mouseX = (event.clientX - windowHalfX);
                mouseY = (event.clientY - windowHalfY);
            });

            // Handle Resize
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });

            // ------------- Animation Loop -------------
            const clock = new THREE.Clock();

            function animate() {
                requestAnimationFrame(animate);

                const time = clock.getElapsedTime();

                // 1. Smooth mouse follow for Hero Object
                targetX = mouseX * 0.001;
                targetY = mouseY * 0.001;
                
                heroGroup.rotation.y += 0.002;
                heroGroup.rotation.x += 0.001;
                
                // Tilt hero based on mouse
                heroGroup.rotation.x += 0.05 * (targetY - heroGroup.rotation.x);
                heroGroup.rotation.y += 0.05 * (targetX - heroGroup.rotation.y);

                // Background subtle movement
                particlesMesh.rotation.y = time * 0.02;

                // 2. Project 3D Crystals precisely to DOM Placeholders
                // Vi bruger en Vector3 og unproject til at finde verdens-koordinater
                crystals.forEach((mesh, index) => {
                    const el = mesh.userData.domElement;
                    const rect = el.getBoundingClientRect();
                    
                    // Tjek om kortet overhovedet er på skærmen med lidt margin
                    const isVisible = rect.bottom > -200 && rect.top < window.innerHeight + 200;
                    mesh.visible = isVisible;

                    if (isVisible) {
                        // Find center af DOM elementet
                        const centerX = rect.left + rect.width / 2;
                        const centerY = rect.top + rect.height / 2;

                        // Konverter til Normalized Device Coordinates (NDC) -1 til +1
                        const ndcX = (centerX / window.innerWidth) * 2 - 1;
                        const ndcY = -(centerY / window.innerHeight) * 2 + 1;

                        // Lav en vektor i NDC plan (z = 0.5 arbitrært)
                        const vector = new THREE.Vector3(ndcX, ndcY, 0.5);
                        vector.unproject(camera);

                        // Retning fra kamera til punktet
                        vector.sub(camera.position).normalize();
                        
                        // Definer en fast afstand fra kameraet hvor vi vil tegne krystallerne
                        const distance = 10; 
                        
                        // Sæt position
                        mesh.position.copy(camera.position).add(vector.multiplyScalar(distance));

                        // Rotation & Hover animation
                        mesh.rotation.y += 0.01;
                        mesh.rotation.x = Math.sin(time * 2 + index) * 0.2;
                        mesh.rotation.z = Math.cos(time * 1.5 + index) * 0.2;

                        // Smooth lerp scale
                        const currentScale = mesh.scale.x;
                        const targetScale = mesh.userData.targetScale;
                        const newScale = currentScale + (targetScale - currentScale) * 0.1;
                        mesh.scale.set(newScale, newScale, newScale);
                        
                        // Forøg glow på hover
                        mesh.material.emissiveIntensity = 0.4 + ((newScale - 1) * 2);
                    }
                });

                // Fade out hero if scrolled way past it
                const scrollY = window.scrollY;
                if (scrollY > window.innerHeight) {
                    heroGroup.visible = false;
                } else {
                    heroGroup.visible = true;
                    // Parallax hero upwards
                    heroGroup.position.y = (scrollY * 0.01);
                }

                renderer.render(scene, camera);
            }

            // Start loop
            animate();
        }
    </script>
